@@ -250,6 +250,30 @@ smgr_bulk_flush(BulkWriteState *bulkstate)
 	if (npending > 1)
 		qsort(pending_writes, npending, sizeof(PendingWrite), buffer_cmp);
 
+	/*
+	 * For Umbra mapped forks, smgrextend() must advance logical EOF and prepare
