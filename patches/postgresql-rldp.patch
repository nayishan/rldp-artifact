+/*-------------------------------------------------------------------------
+ *
+ * umfile.h
+ *    Umbra file/segment manager (backend-local).
+ *
+ * This layer owns backend-local file contexts keyed by RelFileLocatorBackend.
+ * It provides low-level physical file/segment handling for Umbra forks.
+ *
+ *-------------------------------------------------------------------------
+ */
