+		while (bulkstate->relsize <= maxblk)
+		{
+			smgrextend(bulkstate->smgr, bulkstate->forknum,
+					   bulkstate->relsize,
+					   &zero_buffer,
+					   true);
+			bulkstate->relsize++;
