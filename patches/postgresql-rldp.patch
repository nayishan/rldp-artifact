+um_state_uses_chunk_base(UmbraMapPolicy state)
+{
+	return state == UMBRA_MAP_POLICY_REQUIRE_MAP ||
+		state == UMBRA_MAP_POLICY_SKIP_WAL_PENDING_MAP;
+}
