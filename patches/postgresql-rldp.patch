+	if (forknum == INIT_FORKNUM || smgrisinternalfork(forknum))
+		return true;
+
+	smgr = smgropen(rlocator, INVALID_PROC_NUMBER);
+	if (!UmUsesChunkPairedTranslation(smgr, forknum))
+		return true;
+
+	return UmTranslationPhysicalBlockExists(smgr, forknum, blkno);
 }
 
