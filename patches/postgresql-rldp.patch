+MapSBlockBumpPhysicalNblocks(UmbraFileContext *map_ctx, RelFileLocator rnode,
+							 ForkNumber forknum, BlockNumber nblocks,
+							 XLogRecPtr map_lsn)
+{
+	MapSBlockBumpPhysicalState(map_ctx, rnode, forknum, nblocks,
+							   false, true, map_lsn);
+}
