+void
+MapSBlockBumpNextFreePhysBlock(UmbraFileContext *map_ctx, RelFileLocator rnode,
+							   ForkNumber forknum, BlockNumber next_free_pblk,
+							   XLogRecPtr map_lsn)
+{
+	MapSBlockBumpPhysicalState(map_ctx, rnode, forknum, next_free_pblk,
+							   true, false, map_lsn);
